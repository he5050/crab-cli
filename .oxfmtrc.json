{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 120,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    ".crab/",
    ".claude",
    ".omc",
    ".planning",
    ".trae",
    "artifacts/",
    "release/",
    "sessions",
    "var",
    "docs",
    "*.patch",
    "*.backup",
    "*.bak"
  ]
}
